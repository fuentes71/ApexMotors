# Frontend env vars. Copy to .env.local for local dev, or set in the Vercel
# dashboard (Production for master, Preview for the dev branch).

# Same-origin proxy targets: next.config.ts rewrites() sends /api/core/* and
# /api/auth/* to these. INCLUDE the backend global prefix (/core, /auth).
# This keeps the auth cookie first-party.
#   Local (docker):  http://localhost:3002/core   +  http://localhost:3001/auth
#   Prod (Vercel):   the Render hosts below
CORE_PROXY_TARGET=https://apexmotors-core-service.onrender.com/core
AUTH_PROXY_TARGET=https://apexmotors-auth-service.onrender.com/auth

# Real-time sync (BAS-40): DIRECT WebSocket connection to the core-service host.
# NO /core suffix — socket.io lives at the host root, not under the prefix.
# WebSockets don't traverse the Vercel rewrite, so this must be a direct URL.
# Leave UNSET to disable realtime; the app still works without it.
#   Local (docker):  http://localhost:3002    (core-service's direct port)
#   Prod (Vercel):   https://apexmotors-core-service.onrender.com
NEXT_PUBLIC_WS_URL=http://localhost:3002
